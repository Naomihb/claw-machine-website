# Resend (https://resend.com) - required to actually send contact form emails.
# Without this, submissions are only logged to the server console and never emailed.
RESEND_API_KEY=

# Sending address - must be on a domain verified in Resend (e.g. quotes@vegaplaysystems.com)
CONTACT_FROM_EMAIL=

# Optional override - defaults to yuwang@11max.world (set in lib/site-config.ts) if unset
# CONTACT_EMAIL=

# Optional - Google reCAPTCHA v3 spam protection. Leave unset to skip verification.
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY=
